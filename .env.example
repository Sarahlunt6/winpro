# Copy to .env.local for local dev, and set the real values in Vercel.
# Never commit real secrets. See README "Environment variables".

# Phase 2 — quote form delivery via Resend (§6)
# Leave RESEND_API_KEY unset locally to run in dev mode (logs the email, no send).
RESEND_API_KEY=
QUOTE_TO_EMAIL=winprollc363@gmail.com
# Optional. Defaults to Resend's onboarding sender until dirtywinpro.com is verified.
# e.g. QUOTE_FROM_EMAIL="WinPro <quotes@dirtywinpro.com>"
QUOTE_FROM_EMAIL=

# Phase 3 — Instagram section via Behold.so (§7)
BEHOLD_FEED_URL=

# Phase 4 — analytics (§8). Vercel Analytics needs no env var. Optional Google tag:
# set ONE of these to load it (GTM wins if both are set). Leave blank for no tag.
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_GTM_ID=
